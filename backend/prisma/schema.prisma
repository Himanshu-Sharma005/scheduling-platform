generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  username  String   @unique
  timezone  String   @default("Asia/Kolkata")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  eventTypes            EventType[]
  availabilitySchedules AvailabilitySchedule[]

  @@map("users")
}

model EventType {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  title           String
  slug            String
  description     String?
  durationMinutes Int      @default(30) @map("duration_minutes")
  locationType    String   @default("google_meet") @map("location_type")
  color           String   @default("#2563eb")
  bufferBefore    Int      @default(0) @map("buffer_before")
  bufferAfter     Int      @default(0) @map("buffer_after")
  isActive        Boolean  @default(true) @map("is_active")
  position        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  customQuestions CustomQuestion[]

  @@unique([userId, slug])
  @@map("event_types")
}

model AvailabilitySchedule {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  timezone  String   @default("Asia/Kolkata")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules         AvailabilityRule[]
  dateOverrides DateOverride[]

  @@map("availability_schedules")
}

model AvailabilityRule {
  id         Int    @id @default(autoincrement())
  scheduleId Int    @map("schedule_id")
  dayOfWeek  Int    @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime  String @map("start_time") // "09:00"
  endTime    String @map("end_time")   // "17:00"

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("availability_rules")
}

model DateOverride {
  id         Int      @id @default(autoincrement())
  scheduleId Int      @map("schedule_id")
  date       DateTime @db.Date
  isBlocked  Boolean  @default(false) @map("is_blocked")
  startTime  String?  @map("start_time")
  endTime    String?  @map("end_time")

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("date_overrides")
}

model Booking {
  id           Int      @id @default(autoincrement())
  eventTypeId  Int      @map("event_type_id")
  bookerName   String   @map("booker_name")
  bookerEmail  String   @map("booker_email")
  bookerNotes  String?  @map("booker_notes")
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  timezone     String   @default("Asia/Kolkata")
  status       String   @default("confirmed") // confirmed, cancelled, rescheduled
  uid          String   @unique @default(uuid())
  cancelReason String?  @map("cancel_reason")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  eventType EventType       @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  answers   BookingAnswer[]

  @@map("bookings")
}

model CustomQuestion {
  id          Int     @id @default(autoincrement())
  eventTypeId Int     @map("event_type_id")
  label       String
  type        String  @default("text") // text, textarea, select, checkbox
  isRequired  Boolean @default(false) @map("is_required")
  options     Json?
  position    Int     @default(0)

  eventType EventType       @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  answers   BookingAnswer[]

  @@map("custom_questions")
}

model BookingAnswer {
  id         Int    @id @default(autoincrement())
  bookingId  Int    @map("booking_id")
  questionId Int    @map("question_id")
  answer     String

  booking  Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  question CustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("booking_answers")
}
